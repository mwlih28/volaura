# VoLaura admin server konfigurasyonu
# Bu dosyayı `.env` olarak kopyalayıp düzenleyin.

# Sunucu portu (Nginx/Caddy reverse-proxy önünde tipik olarak 3000)
PORT=3000

# Admin paneline giriş için kullanılacak token (uzun, rastgele).
# Üretim için: openssl rand -hex 32
ADMIN_TOKEN=changeme_64_character_random_string

# Public URL (download URL'lerinde kullanılır)
PUBLIC_URL=https://update.volaura.xyz

# Ana signaling backend (vps-server) base URL'i — kullanıcı listesi /
# mesaj export proxy'si için bu adrese HTTPS istekleri yapılır.
SIGNALING_API_BASE=https://volaura.xyz:8444

# Master parola — admin panelinde "Mesajlar" sekmesinden kullanıcı mesajlarını
# çekebilmek için. Aynı değer vps-server .env'sinde de VOLAURA_MASTER_KEY
# (veya SIGNALING_ADMIN_KEY) olarak ayarlanmalıdır.
# Çok güçlü olmalı; PRINTABLE special chars + harfler + sayılar.
# Üretim için örnek: openssl rand -base64 48
VOLAURA_MASTER_KEY=changeme_set_a_very_strong_master_password
